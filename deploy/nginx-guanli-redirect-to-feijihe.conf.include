# guanli.feijihe.top 整站 301 到 feijihe.top/guanli/
# 原因：guanli 子域 SSL 证书与域名不匹配，所有设备均无法正常访问。
# 用法：在 server { listen 443 ssl; server_name guanli.feijihe.top; } 块内首行 include；
#       证书可暂用 feijihe.top 同一张（仅用于完成 TLS 握手后立即 301，用户应收藏 feijihe.top/guanli/login）。

return 301 https://feijihe.top/guanli$request_uri;
