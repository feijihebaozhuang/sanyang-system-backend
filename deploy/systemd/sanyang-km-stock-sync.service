[Unit]
Description=Sanyang Kuaimai stock mirror sync (once)
After=network.target

[Service]
Type=oneshot
User=admin
Group=admin
WorkingDirectory=/www/feijihe/stable
Environment=PYTHONUNBUFFERED=1
ExecStart=/www/feijihe/stable/venv/bin/python3 /www/feijihe/stable/scripts/km_stock_sync_once.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
