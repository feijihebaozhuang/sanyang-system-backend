[Unit]
Description=Sanyang Production (gunicorn :3002)
After=network.target

[Service]
Type=simple
User=admin
Group=admin
WorkingDirectory=/www/feijihe/stable
Environment=PYTHONUNBUFFERED=1
ExecStart=/www/feijihe/stable/venv/bin/gunicorn -w 2 -b 0.0.0.0:3002 --timeout 120 app_production:app
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
