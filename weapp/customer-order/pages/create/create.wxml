<view class="page">
  <view class="card">
    <view class="title">{{name}}</view>
    <view class="label">长 {{isPe ? '(mm)' : '(cm)'}}</view>
    <input class="input" type="digit" value="{{length}}" data-field="length" bindinput="onInput" />
    <view class="label">宽</view>
    <input class="input" type="digit" value="{{width}}" data-field="width" bindinput="onInput" />
    <view class="label">高{{isPe ? '/厚' : ''}}</view>
    <input class="input" type="digit" value="{{height}}" data-field="height" bindinput="onInput" />
    <view class="label" wx:if="{{!isPe}}">尺寸类型</view>
    <radio-group wx:if="{{!isPe}}" bindchange="onDim">
      <label><radio value="outer" checked="{{dimKind==='outer'}}" />外径</label>
      <label style="margin-left:24rpx;"><radio value="inner" checked="{{dimKind==='inner'}}" />内径</label>
    </radio-group>
    <view class="label" wx:if="{{!isPe && materials.length}}">材质</view>
    <view wx:for="{{materials}}" wx:key="key" style="display:inline-block;margin:8rpx;" bindtap="onMat" data-key="{{item.key}}" data-name="{{item.name}}">
      <text style="padding:12rpx 20rpx;border-radius:8rpx;{{material===item.key?'background:#2980b9;color:#fff;':'background:#eee;'}}">{{item.name}}</text>
    </view>
    <view class="label">数量</view>
    <input class="input" type="number" value="{{qty}}" data-field="qty" bindinput="onInput" />
  </view>

  <view class="card" wx:if="{{matchText}}"><text>{{matchText}}</text></view>
  <view class="card" wx:if="{{quoteText}}"><text>{{quoteText}}</text></view>
  <view class="err" wx:if="{{error}}">{{error}}</view>

  <button class="btn-secondary" bindtap="doMatch">匹配 SKU</button>
  <button class="btn-secondary" bindtap="doQuote">自动算价</button>
  <button class="btn-primary" loading="{{submitting}}" bindtap="submitOrder">提交订单</button>
</view>
