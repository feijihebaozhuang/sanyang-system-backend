<view class="page" wx:if="{{item}}">
  <view class="card">
    <view class="title">{{item.order_no}}</view>
    <view>状态：{{item.statusLabel}}</view>
    <view>规格：{{item.length}}×{{item.width}}×{{item.height}} {{item.material}}</view>
    <view>数量：{{item.qty}}</view>
    <view wx:if="{{item.total_price}}">金额：¥{{item.total_price}}</view>
    <view wx:if="{{item.outer_id}}">SKU：{{item.outer_id}}</view>
    <view wx:if="{{item.remark}}">备注：{{item.remark}}</view>
  </view>
</view>
