<view class="page">
  <view style="display:flex;padding:16rpx;background:#fff;">
    <text data-tab="pending_review" bindtap="switchTab" style="flex:1;text-align:center;{{tab==='pending_review'?'color:#2980b9;font-weight:600;':''}}">待审核</text>
    <text data-tab="approved" bindtap="switchTab" style="flex:1;text-align:center;{{tab==='approved'?'color:#2980b9;font-weight:600;':''}}">已通过</text>
    <text data-tab="" bindtap="switchTab" style="flex:1;text-align:center;{{tab===''?'color:#2980b9;font-weight:600;':''}}">全部</text>
  </view>
  <view class="card" wx:for="{{orders}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
    <view class="title">{{item.customer_name}} · {{item.order_no}}</view>
    <text>{{item.category_name}} {{item.spec}} ×{{item.qty}}</text>
    <view style="color:#2980b9;margin-top:8rpx;">{{item.statusLabel}}</view>
  </view>
  <button class="btn" bindtap="logout">退出登录</button>
</view>
