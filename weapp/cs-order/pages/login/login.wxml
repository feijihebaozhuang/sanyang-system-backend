<view class="page">
  <view class="card">
    <view class="title">三羊客服 · 接单审核</view>
    <text style="font-size:24rpx;color:#888;">使用与 3001 相同的账号</text>
    <input class="input" placeholder="账号" bindinput="onUser" />
    <input class="input" password placeholder="密码" bindinput="onPwd" />
