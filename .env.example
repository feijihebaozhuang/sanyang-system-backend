# 复制本文件为 .env 后填写真实值（.env 勿提交 Git）

# ---------- MySQL（必填）----------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=sanyang

# ---------- Flask Session（必填）----------
FLASK_SECRET_KEY=

# ---------- 聚水潭（不用可留空，相关接口会失败）----------
# JST_APP_KEY 即开放平台 appKey，多数与 partnerId 相同；若不同再填 JST_PARTNER_ID。未配置会报「缺少 partnerid」。
JST_APP_KEY=
JST_APP_SECRET=
JST_PARTNER_ID=
# JST_API_URL=https://open.erp321.com/api/open/query.aspx

# ---------- 微信公众号回调（仅 app_cs 校验用，不用可留空）----------
# WECHAT_TOKEN=

# ---------- 1688 开放平台 ----------
# 各店铺共用的 app_key / app_secret（若每个店铺 JSON 里已写则可省略）
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=
ALIBABA_SERVER=gw.open.1688.com
# 用于卖家备注等单店 API；不填则取下方店铺列表第一家 token
# ALIBABA_DEFAULT_ACCESS_TOKEN=

# 店铺列表（二选一）：
# 1）指向 UTF-8 JSON 文件，内容为数组，每项含 shop_name、access_token，可选 app_key、app_secret、server
#    复制 alibaba_shops.example.json 为 alibaba_shops.json（已在 .gitignore），控制台「刷新」token 后更新对应 access_token 并重启服务。
ALIBABA_SHOPS_FILE=alibaba_shops.json
# 2）或直接内联 JSON（单行，注意引号转义）
# ALIBABA_SHOPS_JSON=[{"shop_name":"三羊包装","access_token":"..."}]
