# 复制本文件为 .env 后填写真实值（.env 勿提交 Git）

# ---------- MySQL（必填）----------
# 当前：213 内网 172.19.18.36（8 月到期后改为阿里云 RDS 内网地址）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=sanyang
# 8 月迁 RDS 后只改 MYSQL_HOST / 密码，应用代码与 deploy 不变，见 docs/三机部署方案-小马哥.md

# ---------- Flask Session（必填）----------
FLASK_SECRET_KEY=
# 仅全程 HTTPS 时设为 true。HTTP 访问（如 http://IP:3002）必须保持注释，否则刷新会退回登录页
# SESSION_COOKIE_SECURE=true

# ---------- 聚水潭（不用可留空，相关接口会失败）----------
# JST_APP_KEY 即开放平台 appKey，多数与 partnerId 相同；若不同再填 JST_PARTNER_ID。未配置会报「缺少 partnerid」。
JST_APP_KEY=
JST_APP_SECRET=
JST_PARTNER_ID=
# JST_API_URL=https://open.erp321.com/api/open/query.aspx

# ---------- 快麦 ERP（客服/生产端订单同步；或复制 km_token.json.example 为 km_token.json）----------
# 快麦 ERP（见 km_token.json.example，勿把真实密钥提交 Git）
# KM_APP_KEY=
# KM_APP_SECRET=
# KM_SESSION=
# KM_API_URL=https://gw.superboss.cc/router
# KM_REFRESH_BEFORE_SEC=1814400

# ---------- 权限配置保险库（可选：独立服务器托管 permission_data，业务机只读）----------
# 配置机 GET 地址；业务机填写后从配置机拉取 permission_data，deploy 不会改配置机文件
# PERMISSION_VAULT_URL=http://10.0.0.5:9443/permission_data.json
# PERMISSION_VAULT_TOKEN=
# 仅配置机填写 WRITE_URL；业务机留空 = 锁定，网页无法改工序/材质映射结构
# PERMISSION_VAULT_WRITE_URL=http://127.0.0.1:9443/permission_data

# ---------- 微信公众号回调（仅 app_cs 校验用，不用可留空）----------
# WECHAT_TOKEN=

# ---------- 飞书机器人 ↔ Dify（见 docs/FEISHU_DIFY.md）----------
# FEISHU_DIFY_ENABLED=true
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_ENCRYPT_KEY=
# FEISHU_BOT_OPEN_ID=
# FEISHU_GROUP_REPLY_ALL=false
# WSL 本机 Dify（docker nginx 80）用下面这行；云端才用 api.dify.ai
# DIFY_API_BASE=http://127.0.0.1/v1
# DIFY_API_BASE=https://api.dify.ai/v1
# DIFY_API_KEY=app-xxxxxxxx
# DIFY_TIMEOUT=120
# Dify 应用未配好模型时先用本机 Ollama 回复（可选）
# FEISHU_USE_OLLAMA_FALLBACK=true
# OLLAMA_BASE=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:0.5b

# ---------- 1688 开放平台 ----------
# 各店铺共用的 app_key / app_secret（若每个店铺 JSON 里已写则可省略）
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=
ALIBABA_SERVER=gw.open.1688.com
# 用于卖家备注等单店 API；不填则取下方店铺列表第一家 token
# ALIBABA_DEFAULT_ACCESS_TOKEN=

# 店铺列表（二选一）：
# 1）指向 UTF-8 JSON 文件，内容为数组，每项含 shop_name、access_token，可选 app_key、app_secret、server
#    复制 alibaba_shops.example.json 为 alibaba_shops.json（已在 .gitignore），控制台「刷新」token 后更新对应 access_token 并重启服务。
ALIBABA_SHOPS_FILE=alibaba_shops.json
# 2）或直接内联 JSON（单行，注意引号转义）
# ALIBABA_SHOPS_JSON=[{"shop_name":"三羊包装","access_token":"..."}]
